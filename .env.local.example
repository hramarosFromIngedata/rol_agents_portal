# Copy to .env.local and set your key
# Note: do NOT commit your real key to version control. Copy this file to `.env.local` and fill the value.
N8N_API_KEY=
N8N_HOST=

# Optional: override individual n8n webhook paths (mounted under ${N8N_HOST}/webhook/)
# without touching code. Defaults shown below (lib/webhooks.ts).
# N8N_WEBHOOK_ROL_PORTAL=rol-portal
# N8N_WEBHOOK_MISTRAL_PRICE=mistral-price
# N8N_WEBHOOK_OPENROUTER_PRICE=openrouter-price
# N8N_WEBHOOK_ROL_STORE_META_DATA=rol-store-meta-data